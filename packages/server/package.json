{
  "name": "@mmorts/server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node --require ts-node/register prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/auth": "^5.0.4",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^6.7.1",
    "@mmorts/shared": "workspace:*",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^4.12.0",
    "dotenv": "^16.3.0",
    "fastify": "^4.24.0",
    "fastify-socket.io": "^4.0.0",
    "ioredis": "^5.3.0",
    "socket.io": "^4.8.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.8.0",
    "prisma": "^5.0.0",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0"
  },
  "prisma": {
    "seed": "node --require ts-node/register prisma/seed.ts"
  }
}