datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// JOUEUR
// ─────────────────────────────────────────────
model Player {
  id          String    @id @default(uuid())
  username    String    @unique
  email       String    @unique
  password    String
  villages    Village[]
  createdAt   DateTime  @default(now())
  totalPoints Int       @default(0)
}

// ─────────────────────────────────────────────
// VILLAGE
// ─────────────────────────────────────────────
model Village {
  id   String @id @default(uuid())
  name String
  x    Int
  y    Int

  // Ressources
  wood  Float @default(500)
  stone Float @default(500)
  iron  Float @default(400)
  food  Float @default(100)

  // Niveaux de production (lecture rapide sans jointure)
  timberCampLevel Int @default(1)
  quarryLevel     Int @default(1)
  ironMineLevel   Int @default(1)

  // Bouclier de protection après une attaque (null = pas de bouclier actif)
  shieldUntil DateTime?

  lastTick DateTime @default(now())

  // Relations
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId String

  buildings    BuildingInstance[]
  buildQueue   BuildingQueue?
  troops       Troop[]
  recruitQueue RecruitQueue?

  // Attaques envoyées et reçues
  attacksSent     AttackReport[] @relation("AttackerVillage")
  attacksReceived AttackReport[] @relation("DefenderVillage")

  @@unique([x, y])
}

// ─────────────────────────────────────────────
// BÂTIMENTS
// ─────────────────────────────────────────────
model BuildingInstance {
  id         String @id @default(uuid())
  buildingId String
  level      Int    @default(0)

  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  villageId String

  updatedAt DateTime @updatedAt

  @@unique([villageId, buildingId])
}

model BuildingQueue {
  id          String @id @default(uuid())
  buildingId  String
  targetLevel Int

  startsAt DateTime @default(now())
  endsAt   DateTime

  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  villageId String  @unique
}

// ─────────────────────────────────────────────
// TROUPES
// ─────────────────────────────────────────────

// Stock de troupes disponibles dans un village
model Troop {
  id       String @id @default(uuid())
  unitType String // ex: 'spearman', 'swordsman', 'axeman', 'cavalry', 'archer'
  count    Int    @default(0)

  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  villageId String

  @@unique([villageId, unitType])
}

// File de recrutement (une seule file par village, comme la construction)
model RecruitQueue {
  id       String @id @default(uuid())
  unitType String
  count    Int // Nombre total à recruter
  trained  Int    @default(0) // Nombre déjà recruté (pour affichage progression)

  startsAt DateTime @default(now())
  endsAt   DateTime // Fin du recrutement complet

  village   Village @relation(fields: [villageId], references: [id], onDelete: Cascade)
  villageId String  @unique
}

// ─────────────────────────────────────────────
// COMBAT
// ─────────────────────────────────────────────
model AttackReport {
  id String @id @default(uuid())

  // Villages impliqués
  attackerVillage   Village @relation("AttackerVillage", fields: [attackerVillageId], references: [id], onDelete: Cascade)
  attackerVillageId String

  defenderVillage   Village @relation("DefenderVillage", fields: [defenderVillageId], references: [id], onDelete: Cascade)
  defenderVillageId String

  // Unités envoyées { spearman: 10, cavalry: 5, ... }
  unitsSent Json

  // Unités survivantes après combat
  unitsSurvived Json

  // Unités défenseur avant/après
  defenderUnitsBefore Json
  defenderUnitsAfter  Json

  // Ressources pillées { wood: 500, stone: 200, iron: 100 }
  resourcesLooted Json

  // Points échangés
  pointsLost   Int @default(0) // Points perdus par le défenseur
  pointsGained Int @default(0) // Points gagnés par l'attaquant

  attackerWon Boolean

  createdAt DateTime @default(now())
}
